{
	"name": "preza",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo clean",
		"lint": "turbo lint",
		"typecheck": "turbo typecheck",
		"build:icons": "node ./packages/ui/scripts/build-icons.mjs",
		"web:dev": "turbo dev --filter=@preza/web-app",
		"web:build": "turbo build --filter=@preza/web-app",
		"web:icons": "node ./apps/web-app/src/scripts/build-icons.mjs",
		"web:start": "turbo start --filter=@preza/web-app",
		"ui:build": "turbo build --filter=@preza/ui"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"turbo": "^2.9.5",
		"typescript": "5.5.4"
	},
	"packageManager": "pnpm@10.28.0",
	"engines": {
		"node": ">=18"
	},
	"pnpm": {
		"overrides": {
			"@types/react": "19.2.6",
			"@types/react-dom": "19.2.3"
		},
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"core-js-pure",
			"esbuild",
			"sharp"
		]
	}
}
